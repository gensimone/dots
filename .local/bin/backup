#!/bin/sh


if ! [ $# -gt 0 ]; then
    echo "You need to specify a directory." >&2
    exit 1
fi

rsync \
	--archive \
	--partial \
	--progress \
	--verbose \
    --delete \
	-hhh \
	/home/simone/codes \
	/home/simone/documents \
	/home/simone/music \
	/home/simone/pictures \
	/home/simone/private \
    $1
